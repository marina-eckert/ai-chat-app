generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
  url      = "file:./dev.db"
}

model Conversation {
  id        Int       @id @default(autoincrement())
  title     String
  messages  Message[]
  createdAt DateTime  @default(now())
}

model Message {
  id             Int          @id @default(autoincrement())
  role           String
  content        String
  conversation   Conversation @relation(fields: [conversationId], references: [id], onDelete: Cascade)
  conversationId Int
  createdAt      DateTime     @default(now())
}
